{
  "name": "visashop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "deploy": "npm run cf-typegen && npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply visashop_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply visashop --remote",
    "db:seed:local": "wrangler d1 execute visashop_db --local --file=./drizzle/seed.sql",
    "db:seed:remote": "wrangler d1 execute visashop_db --remote --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "aws4fetch": "^1.0.20",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.91.0"
  }
}
